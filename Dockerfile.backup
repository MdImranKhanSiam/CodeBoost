FROM alpine:3.19

# Install postgresql-client and dcron for cron jobs
RUN apk add --no-cache postgresql16-client dcron

# Copy backup script
COPY scripts/backup.sh /backup.sh
RUN chmod +x /backup.sh

# Add cron job: run backup every day at 2:00 AM
RUN echo "0 2 * * * /backup.sh >> /backups/backup.log 2>&1" >> /var/spool/cron/crontabs/root

# Run cron in foreground
CMD ["crond", "-f", "-l", "8"]
